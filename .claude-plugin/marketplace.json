{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "michelsciortino-marketplace",
  "description": "My personal marketplace for testing and development. Not an official Anthropic marketplace.",
  "owner": {
    "name": "@michelsciortino"
  },
  "plugins": [
    {
      "name": "dart-lsp",
      "description": "Dart/Flutter language server",
      "version": "1.0.0",
      "author": {
        "name": "@michelsciortino"
      },
      "source": {
        "source": "git-subdir",
        "url": "https://github.com/michelsciortino/claude-plugins.git",
        "path": "external_plugins/dart-lsp",
        "ref": "main"
      },
      "category": "development",
      "strict": false,
      "lspServers": {
        "dart": {
          "command": "dart",
          "args": [
            "language-server"
          ],
          "extensionToLanguage": {
            ".dart": "dart"
          }
        }
      },
      "tags": [
        "community-managed"
      ]
    }
  ]
}